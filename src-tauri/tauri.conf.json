{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MKVN Proxy Manager",
  "version": "0.2.1",
  "identifier": "com.mkvn-proxy-manager.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MKVN Proxy Manager",
        "width": 1400,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
